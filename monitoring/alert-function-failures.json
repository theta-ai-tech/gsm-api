{
  "displayName": "GSM Functions — execution failures",
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "Cloud Function executions with status != ok for 5m",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_function\" AND metric.type=\"cloudfunctions.googleapis.com/function/execution_count\" AND metric.label.status!=\"ok\"",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM",
            "groupByFields": ["resource.label.function_name"]
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0.05,
        "duration": "300s",
        "trigger": { "count": 1 }
      }
    }
  ],
  "alertStrategy": { "autoClose": "1800s" },
  "notificationChannels": ["${NOTIFICATION_CHANNEL}"],
  "documentation": {
    "content": "A GSM Cloud Function (match-cache triggers or the scheduled leaderboard job) is failing. Note: Gen2 functions also emit run.googleapis.com metrics under resource.type=cloud_run_revision — add a matching condition if a function is Gen2-only. Runbook: ${RUNBOOK_URL}",
    "mimeType": "text/markdown"
  }
}
