{
  "displayName": "GSM Firestore — read/write burn high",
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "Firestore document reads > 500/s for 5m",
      "conditionThreshold": {
        "filter": "resource.type=\"firestore_instance\" AND metric.type=\"firestore.googleapis.com/document/read_count\"",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 500,
        "duration": "300s",
        "trigger": { "count": 1 }
      }
    },
    {
      "displayName": "Firestore document writes > 200/s for 5m",
      "conditionThreshold": {
        "filter": "resource.type=\"firestore_instance\" AND metric.type=\"firestore.googleapis.com/document/write_count\"",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 200,
        "duration": "300s",
        "trigger": { "count": 1 }
      }
    }
  ],
  "alertStrategy": { "autoClose": "1800s" },
  "notificationChannels": ["${NOTIFICATION_CHANNEL}"],
  "documentation": {
    "content": "Firestore read/write volume is unusually high — possible runaway query, hot loop, or quota-burn cost risk. Thresholds are starting points; tune to observed baseline. Runbook: ${RUNBOOK_URL}",
    "mimeType": "text/markdown"
  }
}
