// LOCAL DEV ONLY — NOT DEPLOYED TO PROD
// Use this file temporarily if you need direct Firestore emulator access.
// The emulator admin REST endpoint (http://127.0.0.1:8082/emulator/v1/...)
// bypasses rules without needing this file.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
